# Backend Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# ============================================================
# ENVIRONMENT CONFIGURATION
# ============================================================

# Environment type: development, staging, or production
ENVIRONMENT=development

# ============================================================
# DATABASE CONFIGURATION
# ============================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://localhost/vialia_dev

# ============================================================
# HUGGING FACE AI INTEGRATION
# ============================================================

# Hugging Face API Token for AI features
# Get your token from: https://huggingface.co/settings/tokens
# - Choose "Fine-grained tokens"
# - Grant "Inference API" read access
# - Leave repo access blank if just using inference API
# 
# WITHOUT this token:
# - App still runs normally
# - All non-AI endpoints work
# - AI endpoint (/emergencia/reportar) is disabled
# 
# Leave blank for development if testing without AI
HF_API_TOKEN=

# Optional: Override default models (usually not needed)
# HF_AUDIO_MODEL=openai/whisper-tiny
# HF_VISION_MODEL=facebook/detr-resnet-50

# ============================================================
# RENDER PRODUCTION DEPLOYMENT
# ============================================================

# Render automatically provides this when deployed
# Don't set locally - only used in production
# RENDER_EXTERNAL_URL=https://vialia-backend.onrender.com

# Optional: Custom frontend URL (if different from Render)
# FRONTEND_URL=https://vialia-frontend.onrender.com

# ============================================================
# EMAIL/NOTIFICATION CONFIGURATION (if using)
# ============================================================

# SMTP configuration for sending emails
# Example: Gmail account
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password  # Not your regular password!

# Sendgrid alternative (if preferred)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@vialia.com

# ============================================================
# FIREBASE CONFIGURATION (if using)
# ============================================================

# Firebase credentials (if using Firebase services)
# These are usually set via GOOGLE_APPLICATION_CREDENTIALS
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_API_KEY=your-api-key

# ============================================================
# LOGGING CONFIGURATION
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Log file path (if rotating logs)
# LOG_FILE=/var/log/vialia/backend.log

# ============================================================
# SECURITY CONFIGURATION
# ============================================================

# API keys (if your app uses them)
# API_KEY=your-secret-key

# JWT secret (if implementing authentication changes)
# SECRET_KEY=your-very-long-random-secret-key-here

# CORS settings (only use "*" in development!)
# CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:8100

# ============================================================
# RATE LIMITING (if implemented)
# ============================================================

# Maximum requests per minute per IP
# RATE_LIMIT_PER_MINUTE=60

# ============================================================
# FILE UPLOAD CONFIGURATION
# ============================================================

# Maximum file upload sizes (in MB)
# These are enforced by app/api/v1/endpoints/emergencia.py
MAX_AUDIO_SIZE_MB=25
MAX_IMAGE_SIZE_MB=10

# Upload directory (if storing files locally - not recommended for Render)
# UPLOAD_DIR=/tmp/uploads

# ============================================================
# DEVELOPMENT UTILITIES
# ============================================================

# Enable debug mode (NEVER in production!)
DEBUG=False

# Seed database on startup (useful for development)
# SEED_DATABASE=True

# Reload on file changes (only for uvicorn dev mode)
# RELOAD=True

# ============================================================
# AI MODEL ADVANCED CONFIGURATION (rarely needed)
# ============================================================

# Hugging Face Inference API timeout (seconds)
# HF_TIMEOUT=30

# Retry policy for failed AI requests
# HF_MAX_RETRIES=3

# ============================================================
# NOTES
# ============================================================

# Local Development Setup:
# 1. Create .env file in backend/ directory
# 2. Run: pip install python-dotenv
# 3. Uncomment and fill only the variables you need
# 4. Leave HF_API_TOKEN empty if testing without AI features

# Production Deployment (Render):
# 1. Set environment variables in Render dashboard
# 2. Never use .env file in production
# 3. Render provides DATABASE_URL and RENDER_EXTERNAL_URL automatically

# For more details, see:
# - PRODUCTION_DEPLOYMENT_GUIDE.md
# - PULL_REQUEST_SUMMARY.md
