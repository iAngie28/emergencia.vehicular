@startuml
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam Activity {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    ArrowColor #2C3E50
}
skinparam StartColor #1E8449
skinparam EndColor #922B21

start
:Seleccionar Caso de Uso (CU) a probar;
:Preparar entorno y datos de prueba (Precondiciones);
:Ejecutar acciones en el Frontend (React/Móvil);
:El Backend (FastAPI) procesa la petición;

if (¿El Resultado Esperado coincide con el Resultado Obtenido?) then (Sí)
    :Marcar Caso de Prueba como **APROBADO**;
else (No)
    repeat
        :Registrar BUG (Incidencia);
        :Desarrollador corrige el código;
        :Desplegar nueva versión;
        note right: Regresión
        :Re-ejecutar Caso de Prueba;
    repeat while (¿Falla nuevamente?) is (Sí)
endif

:Generar Reporte de Pruebas;
stop
@enduml