@startuml
top to bottom direction
skinparam shadowing false
skinparam componentStyle uml2
skinparam nodesep 40
skinparam ranksep 60

skinparam component {
    BackgroundColor #FADBD8
    BorderColor #922B21
    BorderThickness 1.2
}
skinparam interface {
    BackgroundColor #FADBD8
    BorderColor #922B21
}
skinparam arrow {
    Color #555555
    Thickness 1.2
}

frame "cmp 3. Gestión Técnico" {
    package "Gestión Técnico" {
        
        ' Capa de Vistas
        component "TechRegister.tsx" as V1
        component "AssignTech.tsx" as V2
        component "FieldStatus.tsx" as V3

        ' Interfaces
        interface " " as I1
        interface " " as I2

        ' Capa de Controladores
        component "TecnicoRouter.py" as C1
        component "AsignacionRouter.py" as C2

        ' Capa de Modelos
        component "Técnico" as M1
        component "Asignación" as M2

        ' Conexiones
        V1 --( I1
        I1 -- C1

        V2 --( I2
        V3 --( I2
        I2 -- C2

        C1 ..> M1
        C2 ..> M2
        C2 ..> M1
    }
}
@enduml