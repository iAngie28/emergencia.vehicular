@startuml
' --- Configuración visual para imitar la imagen de referencia ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 50
skinparam ranksep 70

skinparam componentStyle uml2

skinparam component {
    BackgroundColor #FDEBD0
    BorderColor #A04000
    BorderThickness 1.2
}

skinparam folder {
    BackgroundColor #FDEBD0
    BorderColor #A04000
    BorderThickness 1.2
}

skinparam arrow {
    Color #333333
    Thickness 1.5
    Style dashed
}

' Marco exterior idéntico al de la imagen
frame "cmp Diagrama de Componentes: Sistema" {

    ' Componente central
    component "API Principal (Index)\n" as Main {
        note "Punto de entrada principal\ny enrutador del sistema." as N1
    }

    ' Paquetes del sistema
    folder "1. Gestión de Usuarios\n<<(from Paquetes)>>" as P1
    folder "2. Gestión de Asistencia\n<<(from Paquetes)>>" as P2
    folder "3. Gestión Técnico\n<<(from Paquetes)>>" as P3
    folder "4. Reportes y Notificaciones\n<<(from Paquetes)>>" as P4
    folder "Base de datos (PostgreSQL)\n<<(from Paquetes)>>" as DB

    ' Direccionamiento manual para crear la forma de "estrella" de tu imagen
    Main .up.> P1
    Main .up.> P2
    Main .up.> P3
    
    Main .right.> P4
    
    Main .left.> DB
}

@enduml