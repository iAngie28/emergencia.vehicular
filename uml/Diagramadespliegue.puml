@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 50
skinparam ranksep 80

skinparam node {
    BackgroundColor #FAFAFA
    BorderColor #2C3E50
    BorderThickness 1.5
}
skinparam database {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam component {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1
}
skinparam cloud {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

node "Dispositivo Móvil (Smartphone)" as NodoMovil {
    component "Aplicación Móvil\n<<Frontend>>" as AppMovil
}

node "Computadora de Escritorio" as NodoWeb {
    component "Navegador Web\n<<SPA Frontend>>" as AppWeb
}

node "Infraestructura en la Nube (Servidor Principal)" as ServidorNube {
    
    node "Servidor de Aplicaciones" as ServidorApp {
        component "Backend Core\n<<FastAPI>>" as API
    }
    
    node "Servidor de Procesamiento IA" as ServidorIA {
        component "Modelos de IA\n<<Visión, NLP, Audio>>" as MotorIA
    }
    
    database "Servidor de Base de Datos" as ServidorBD {
        component "PostgreSQL\n<<Relacional>>" as DB
    }
}

cloud "Servicios Externos (APIs)" as Externos {
    component "Pasarela de Pagos\n<<Stripe / PayPal>>" as Pagos
    component "Servicio Push\n<<Firebase FCM>>" as Push
}

' --- Conexiones y Protocolos ---
AppMovil ..> API : <<protocolo>>\nHTTPS / WSS
AppWeb ..> API : <<protocolo>>\nHTTPS

API ..> DB : <<protocolo>>\nTCP/IP
API ..> MotorIA : <<protocolo>>\nREST Interno / gRPC

API ..> Pagos : <<protocolo>>\nHTTPS
API ..> Push : <<protocolo>>\nHTTPS

@enduml