@startuml
top to bottom direction

' --- Configuración visual idéntica a tu ejemplo ---
skinparam shadowing false
skinparam packageStyle strictuml
skinparam nodesep 20
skinparam ranksep 50

skinparam package {
    BackgroundColor #FDEBD0
    BorderColor #A04000
    BorderThickness 1.2
}
skinparam arrow {
    Color #333333
    Thickness 1.2
}

' --- CAPA DE PRESENTACIÓN ---
package "Capa de Presentacion" as CP {
    package "P1. Gestion de Usuarios " as CP_P1
    package "P2. Gestion de Asistencia " as CP_P2
    package "P3. Gestion Tecnico " as CP_P3
    package "P4. Reportes y Notific. " as CP_P4
    
    ' Forzar alineación horizontal
    CP_P1 -[hidden]right- CP_P2
    CP_P2 -[hidden]right- CP_P3
    CP_P3 -[hidden]right- CP_P4
}

' --- CAPA DE LÓGICA DE NEGOCIO ---
package "Capa de Logica de Negocio" as CLN {
    package "P1. Gestion de Usuarios" as CLN_P1
    package "P2. Gestion de Asistencia" as CLN_P2
    package "P3. Gestion Tecnico" as CLN_P3
    package "P4. Reportes y Notific." as CLN_P4
    
    CLN_P1 -[hidden]right- CLN_P2
    CLN_P2 -[hidden]right- CLN_P3
    CLN_P3 -[hidden]right- CLN_P4
}

' --- CAPA DE ACCESO A DATOS ---
package "Capa de Acceso a Datos" as CAD {
    package "P1. Gestion de Usuario" as CAD_P1
    package "P2. Gestion de Asistencia" as CAD_P2
    package "P3. Gestion Tecnico" as CAD_P3
    package "P4. Reportes y Notific." as CAD_P4
    
    CAD_P1 -[hidden]right- CAD_P2
    CAD_P2 -[hidden]right- CAD_P3
    CAD_P3 -[hidden]right- CAD_P4
}

' --- TECNOLOGÍAS BASE ---
package "FastAPI (Backend Core)" as Fwk
package "PostgreSQL (BDD)" as DB
package "Plataforma Inteligente App" as App

' --- RELACIONES MULTICAPA ---
' Presentación -> Lógica
CP_P1 ..|> CLN_P1
CP_P2 ..|> CLN_P2
CP_P3 ..|> CLN_P3
CP_P4 ..|> CLN_P4

' Lógica -> Acceso a Datos
CLN_P1 ..|> CAD_P1
CLN_P2 ..|> CAD_P2
CLN_P3 ..|> CAD_P3
CLN_P4 ..|> CAD_P4

' Acceso a Datos -> Framework/Herramientas
CAD_P1 ..|> Fwk
CAD_P2 ..|> Fwk
CAD_P3 ..|> Fwk
CAD_P4 ..|> Fwk

' Conexiones finales de tecnología
Fwk ..|> DB
Fwk ..|> App
DB ..|> App

@enduml