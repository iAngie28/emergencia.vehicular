@startuml
left to right direction

' Configuración estricta UML 2.5
skinparam shadowing false
skinparam packageStyle strictuml
skinparam nodesep 20
skinparam ranksep 80

skinparam usecase {
  BackgroundColor White
  BorderColor Black
}
skinparam actor {
  BackgroundColor White
  BorderColor Black
}
skinparam arrow {
  Color #2c3e50
  Thickness 1.2
}

actor "Taller\n(Web)" as Taller
actor "Cliente\n(Móvil)" as Cliente
actor "Técnico\n(Móvil)" as Tecnico

package "1. Gestión de Usuarios" #LightBlue {
    usecase "CU-01: Iniciar sesión" as CU1
    usecase "CU-02: Cerrar sesión" as CU2
    usecase "CU-03: Registrar usuario" as CU3
    usecase "CU-04: Visualizar listado de usuarios" as CU4
    usecase "CU-06: Recuperar contraseña" as CU6
    usecase "CU-07: Gestionar perfil de usuario" as CU7
    usecase "CU-08: Registrar vehículo" as CU8

    ' Relaciones de dependencia UML 2.5 correctas
    CU6 ..> CU1 : <<include>>
    CU4 ..> CU3 : <<include>>
}

' Relaciones del Taller
Taller -- CU1
Taller -- CU2
Taller -- CU3
Taller -- CU4
Taller -- CU6
Taller -- CU7
Taller -- CU8

' Relaciones del Técnico
Tecnico -- CU1
Tecnico -- CU2
Tecnico -- CU7

' Relaciones del Cliente
CU1 -- Cliente
CU2 -- Cliente
CU3 -- Cliente
CU6 -- Cliente
CU7 -- Cliente
CU8 -- Cliente

@enduml