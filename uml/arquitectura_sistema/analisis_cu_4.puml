@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Taller" as T
boundary "Vista Usuarios" as V
control "usuario.py listar_admins_de_mi_taller()" as C
entity "Usuario" as E

T -> V : 1: Ingresar a módulo Usuarios()
V -> C : 2: GET /usuarios/mis-administradores
C -> E : 3: Query Usuario por taller_id
E --> C : 4: Retornar lista de usuarios()
C --> V : 5: Renderizar tabla()
@enduml