@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Cliente" as U
boundary "Vista Emergencia" as V
control "incidentes.py crear_nuevo_incidente() + evidencias.py crear_evidencia()" as C
entity "Incidente + Evidencia" as E

U -> V : 1: Reportar emergencia con evidencia()
V -> C : 2: POST /incidentes y POST /evidencias
C -> E : 3: incidente_crud.create() y evidencia_crud.create()
E --> C : 4: Retornar número de solicitud()
C --> V : 5: Mostrar confirmación del reporte()
@enduml
