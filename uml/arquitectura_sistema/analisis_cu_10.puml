@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Cliente" as U
boundary "Vista Estado de Solicitud" as V
control "incidentes.py leer_mis_atenciones()/leer_incidentes_pendientes()" as C
entity "Incidente" as E

U -> V : 1: Consultar estado de solicitud()
V -> C : 2: GET /incidentes/mis-atenciones o /pendientes
C -> E : 3: incidente_crud.obtener_por_taller()/obtener_pendientes()
E --> C : 4: Retornar progreso y asignación()
C --> V : 5: Mostrar estado actualizado()
@enduml
