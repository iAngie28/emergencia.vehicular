@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Cliente" as U
boundary "Vista Vehículos" as V
control "vehiculos.py registrar_vehiculo()" as C
entity "Vehiculo" as E

U -> V : 1: Registrar nuevo vehículo()
V -> C : 2: POST /vehiculos
C -> E : 3: vehiculo_crud.create()
E --> C : 4: Confirmar registro()
C --> V : 5: Mostrar vehículo registrado()
@enduml
