@startuml
top to bottom direction

' Configuración para igualar el diseño de tu imagen
skinparam shadowing false
skinparam packageStyle strictuml
skinparam nodesep 50
skinparam ranksep 70

' Fondo azul general
skinparam rectangle {
    BackgroundColor #ADD8E6
    BorderColor Black
    BorderThickness 2
    FontSize 16
    FontStyle bold
}

' Paquetes con fondo gris claro
skinparam package {
    BackgroundColor #E8F4F8
    BorderColor #333333
    BorderThickness 1
}

skinparam arrow {
    Color #333333
    Thickness 1.5
}

rectangle "Diagrama general de paquetes" {
    
    package "4. Reportes y Notificaciones" as P4
    package "3. Gestión Técnico" as P3
    package "2. Gestión de Asistencia" as P2
    package "1. Gestión de Usuarios" as P1
    
    ' --- Corrección UML 2.5: Reemplazo de <<include>> por <<import>> ---
    
    P4 ..> P3 : <<use>>
    P4 ..> P2 : <<use>>
    P4 ..> P1 : <<use>>
    
    P3 ..> P2 : <<import>>
    P3 ..> P1 : <<import>>
    
    P2 ..> P1 : <<import>>
}

@enduml