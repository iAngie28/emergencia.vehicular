@startuml
left to right direction

' Configuración estricta UML 2.5 sin actores
skinparam packageStyle strictuml
skinparam nodesep 20
skinparam ranksep 80
skinparam usecase {
  BackgroundColor White
  BorderColor Black
}

package "1. Gestión de Usuarios" #LightBlue {
    usecase "CU-01: Iniciar sesión" as CU1
    usecase "CU-02: Cerrar sesión" as CU2
    usecase "CU-03: Registrar usuario" as CU3
    usecase "CU-04: Visualizar listado de usuarios" as CU4
    usecase "CU-06: Recuperar contraseña" as CU6
    usecase "CU-07: Gestionar perfil de usuario" as CU7
    usecase "CU-08: Registrar vehículo" as CU8

    CU6 ..> CU1 : <<include>>
    CU4 ..> CU3 : <<include>>

}





@enduml