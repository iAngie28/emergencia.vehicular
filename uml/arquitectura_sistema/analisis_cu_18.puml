@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Taller" as U
boundary "Vista Aceptar o Rechazar" as V
control "incidentes.py actualizar_estado_solicitud()" as C
entity "Incidente" as E

U -> V : 1: Evaluar solicitud()
V -> C : 2: PUT /incidentes/{id}/estado
C -> E : 3: Actualizar estado a aceptado o rechazado
E --> C : 4: Confirmar cambio de estado()
C --> V : 5: Mostrar resultado()
@enduml