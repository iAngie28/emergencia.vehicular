@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Cliente" as U
boundary "Vista Pago" as V
control "pagos.py generar_cobro_incidente()/confirmar_pago()" as C
entity "Pago + Incidente" as E

U -> V : 1: Iniciar pago del servicio()
V -> C : 2: POST /pagos/generar-cobro/{incidente_id}
C -> E : 3: pago_crud.create() y actualización de incidente
E --> C : 4: Confirmar estado del pago()
C --> V : 5: Mostrar comprobante de pago()
@enduml
