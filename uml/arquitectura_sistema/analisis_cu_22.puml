@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Taller" as U
boundary "Vista Historial y Metricas" as V
control "atenciones.py listar_historial_y_metricas()" as C
entity "Incidente + Servicio" as E

U -> V : 1: Consultar historial de atenciones()
V -> C : 2: GET /atenciones/historial
C -> E : 3: Obtener atenciones y metricas
E --> C : 4: Retornar historial consolidado()
C --> V : 5: Mostrar historial y metricas()
@enduml