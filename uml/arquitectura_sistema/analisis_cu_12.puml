@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Usuario\n(Cliente/Taller)" as U
boundary "Vista Comunicación" as V
control "talleres.py leer_taller_por_id()" as C
entity "Taller + Incidente" as E

U -> V : 1: Seleccionar canal de contacto()
V -> C : 2: GET /talleres/{id} y datos del incidente
C -> E : 3: Obtener telefono_cliente y contacto del taller
E --> C : 4: Retornar datos de contacto()
C --> V : 5: Redirigir a WhatsApp o teléfono()
@enduml
