@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Taller" as T
boundary "Vista Bitácora" as V
control "bitacora.py leer_historial_auditoria()" as C
entity "Bitacora + Usuario" as E

T -> V : 1: Ingresar a módulo Bitácora()
V -> C : 2: GET /bitacora
C -> E : 3: JOIN Bitacora con Usuario
E --> C : 4: Retornar datos()
C --> V : 5: Mostrar historial en pantalla()
@enduml