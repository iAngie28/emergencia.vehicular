@startuml
left to right direction

' --- Estilo Formal Enterprise Architect ---
skinparam shadowing false
skinparam defaultFontName sans-serif
skinparam nodesep 60
skinparam ranksep 70

skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #333333
    BorderThickness 1.5
}
skinparam boundary {
    BackgroundColor #D6EAF8
    BorderColor #2874A6
    BorderThickness 1.5
}
skinparam control {
    BackgroundColor #FDEBD0
    BorderColor #B9770E
    BorderThickness 1.5
}
skinparam entity {
    BackgroundColor #D5F5E3
    BorderColor #1E8449
    BorderThickness 1.5
}
skinparam arrow {
    Color #2C3E50
    Thickness 1.5
    FontColor #17202A
    FontSize 12
}
' ------------------------------------------

actor "Taller" as U
boundary "Vista Asignar Tecnico" as V
control "incidentes.py asignar_tecnico_a_incidente()" as C
entity "Incidente + Tecnico" as E

U -> V : 1: Asignar tecnico a incidente()
V -> C : 2: POST /incidentes/{id}/asignar-tecnico
C -> E : 3: Vincular tecnico y actualizar solicitud
E --> C : 4: Confirmar asignacion()
C --> V : 5: Mostrar tecnico asignado()
@enduml